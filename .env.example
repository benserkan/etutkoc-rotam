APP_NAME=LGS Takip
DATABASE_URL=sqlite:///./lgs.db
SESSION_SECRET=change-me-to-a-long-random-string
DEBUG=true

# Email bildirimleri (false ise log-only, mail gönderilmez)
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ETÜTKOÇ <noreply@etutkoc.local>
SMTP_USE_TLS=true
SMTP_USE_SSL=false
APP_BASE_URL=http://127.0.0.1:8081

# AI kitap şablonu önerisi (opsiyonel — yoksa AI butonu hata mesajı gösterir).
# Anthropic Claude Haiku kullanılır; maliyet çok düşük (~penny/call).
ANTHROPIC_API_KEY=

# WhatsApp Cloud API (Meta Business)
# https://developers.facebook.com/docs/whatsapp/cloud-api
# false → stub mode (log-only, sahte external_id ile başarılı sayılır)
# true → gerçek gönderim (token + phone_number_id şart)
WHATSAPP_ENABLED=false
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Webhook imza doğrulama için Meta App Settings → Basic → App Secret
WHATSAPP_APP_SECRET=
# Webhook GET verify token — sen seç, Meta paneline aynısını yaz
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_DEFAULT_LANGUAGE=tr
