# =============================================================================
# ETÜTKOÇ Production .env — `deploy/.env` olarak kopyala + güçlü değerlerle doldur
# (gitignored — kesinlikle commit ETMEYİN)
# =============================================================================

# ---- Domain ----
# Lightsail Static IP'sini bu domain'in A kaydına bağlamış olmalısınız.
# Caddy bunu Let's Encrypt sertifikası için kullanır.
PUBLIC_DOMAIN=app.etutkoc.com

# ---- PostgreSQL ----
POSTGRES_DB=lgs
POSTGRES_USER=lgs
POSTGRES_PASSWORD=__STRONG_RANDOM_64_CHARS__

# ---- FastAPI ----
# 32+ byte rastgele — örn: openssl rand -hex 32
SESSION_SECRET=__STRONG_RANDOM_64_CHARS__
JWT_SECRET=__STRONG_RANDOM_64_CHARS__

# ---- Gunicorn worker sayısı ----
# Lightsail 2 vCPU plan için 2-4 önerilir; küçük VPS için 2
WEB_WORKERS=2

# ---- Email (SMTP) ----
EMAIL_ENABLED=true
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=postmaster@etutkoc.com
SMTP_PASSWORD=__SMTP_PASSWORD__
SMTP_FROM=ETÜTKOÇ <noreply@etutkoc.com>

# ---- WhatsApp Cloud API (Meta Business Manager) ----
# Meta token'ları hazır değilse WHATSAPP_ENABLED=false yapın (dispatcher hata üretmesin)
WHATSAPP_ENABLED=true
WHATSAPP_PHONE_NUMBER_ID=__META_NUMARASI__
WHATSAPP_ACCESS_TOKEN=__META_BEARER_TOKEN__
WHATSAPP_APP_SECRET=__META_APP_SECRET__
WHATSAPP_WEBHOOK_VERIFY_TOKEN=__SENIN_SECISIN__

# ---- Yapay Zekâ (Google Gemini) ----
# Boş bırakılabilir → süper admin → AI Ayarları panelinden de girilebilir (DB şifreli).
# GEMINI_API_KEY: tek satırda virgülle çoklu — ilk=ücretli (öğrenci verisi), kalan=ücretsiz
GEMINI_API_KEY=
GEMINI_PAID_API_KEY=
GEMINI_FREE_API_KEYS=
GEMINI_PAID_MODEL=gemini-2.5-pro
GEMINI_FREE_MODEL=gemini-2.5-flash

# ---- Cloudflare Turnstile (CAPTCHA — login/signup bot koruması) ----
# İkisi de boşsa Turnstile otomatik KAPALI (sistem yine çalışır). Açmak için doldur.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_ENABLED=1

# ---- SMS Sağlayıcı (telefon doğrulama OTP) ----
# SMS_ENABLED=false iken OTP konsol log'una düşer + UI'da dev_test_code görünür (sadece test).
# true yapmak için sağlayıcı hesabı + ONAYLI BAŞLIK (sender ID) gerekli.
# Tarife: paket başına ücretlendirilir; demo/test için en küçük paket yeterli (~100-1000 SMS).
SMS_ENABLED=false
# Sağlayıcı seçimi: "vatansms" (default — TC + e-devlet belgesi ile BİREYSEL hesap)
# veya "netgsm" (legacy — şirket/VKN gerekir).
SMS_PROVIDER=vatansms

# ---- VatanSMS (default — şirket gerekmez) ----
# Hesap: vatansms.com / vatansms.net → bireysel üyelik → TC + e-devlet yerleşim belgesi
# API bilgileri: VatanSMS panel → Geliştirici → API Bilgileri
# Onaylı başlık: Panel → Mesaj Başlığı → ekle (örn. ETUTKOC, max 11 karakter, onay 1-2 saat)
VATANSMS_API_ID=
VATANSMS_API_KEY=
VATANSMS_SENDER=
VATANSMS_BASE_URL=https://api.vatansms.net

# ---- Netgsm (legacy — şirket/VKN gerekir) ----
# Yalnız SMS_PROVIDER=netgsm yaparsan kullanılır.
NETGSM_USER=
NETGSM_PASSWORD=
NETGSM_HEADER=
NETGSM_BASE_URL=https://api.netgsm.com.tr

# =============================================================================
# Plausible (self-host) — gizlilik-dostu site analitiği (çerezsiz, KVKK)
# Kurulum rehberi: deploy/PLAUSIBLE_SETUP.md
# Kapalı bırakmak için PLAUSIBLE_DOMAIN'i boş bırak (script basılmaz, panel kurulum
# rehberi gösterir). Plausible stack'i (plausible/clickhouse) çalışmasa da uygulama
# normal çalışır.
# =============================================================================
# --- Plausible servisi (docker-compose plausible/clickhouse) ---
# Panonun çalışacağı alt alan adı (BASE_URL host kısmı), örn. analytics.etutkoc.com
PLAUSIBLE_HOST=analytics.etutkoc.com
# openssl rand -base64 48   (zorunlu, gizli)
PLAUSIBLE_SECRET_KEY_BASE=
# openssl rand -base64 32   (zorunlu, gizli — TOTP şifreleme)
PLAUSIBLE_TOTP_VAULT_KEY=
# Plausible'ın kendi Postgres parolası (openssl rand -hex 24)
PLAUSIBLE_DB_PASSWORD=
# İlk admin oluşturulduktan sonra true bırak
PLAUSIBLE_DISABLE_REGISTRATION=true

# --- Next.js tarafı (izleme script'i + süper admin gömülü pano) ---
# İzleme script'inin data-domain'i = sitenin yayın alanı (örn. rotam.etutkoc.com)
# BOŞ bırakılırsa izleme script'i hiç basılmaz (analitik kapalı).
PLAUSIBLE_DOMAIN=
# Script yolu — first-party (Caddy /js/* → plausible). Genelde değiştirme.
PLAUSIBLE_SRC=/js/script.js
# Süper admin gömülü panosu — Plausible "Shared Link" embed bağlantısı
# (Plausible → Site Settings → Visibility → Shared Links → +Add → embed URL).
PLAUSIBLE_SHARED_URL=
# "Tam panel" linki (yeni sekme) — pano alt alan adı
PLAUSIBLE_DASHBOARD_URL=https://analytics.etutkoc.com
