<clickhouse>
    <!-- Plausible self-host: sorgu loglarini kapat (disk tasarrufu). -->
    <profiles>
        <default>
            <log_queries>0</log_queries>
            <log_query_threads>0</log_query_threads>
        </default>
    </profiles>
    <!-- ClickHouse 24.12 'default' kullaniciyi ag uzerinden sifresiz baglanmaya
         kapatiyor → Plausible (ayri container) baglanamiyor. Acikca sifresiz +
         tum-ag erisimli tanimla. Servis YALNIZ ic Docker aginda (disa kapali). -->
    <users>
        <default>
            <password></password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
        </default>
    </users>
</clickhouse>
