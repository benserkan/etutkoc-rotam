{
  "expo": {
    "name": "ETÜTKOÇ Rotam",
    "slug": "etutkoc-rotam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "etutkocrotam",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.etutkoc.rotam",
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.etutkoc.rotam",
      "googleServicesFile": "./google-services.json",
      "blockedPermissions": [
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280,
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#FFFFFF"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#0e7490"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "ETÜTKOÇ Rotam, koçluk seansı notlarını sesle yazabilmen (dikte) için mikrofona erişir. Ses kaydı saklanmaz; yalnız metne çevrilir."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e70c9fe3-562c-44a3-ae92-36ad943fed52"
      }
    },
    "owner": "etutkoc",
    "updates": {
      "url": "https://u.expo.dev/e70c9fe3-562c-44a3-ae92-36ad943fed52",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
